{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist-server",
    "rootDir": "./src/server",
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "include": ["src/server"]
}
